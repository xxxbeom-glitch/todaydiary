# ---------------------------------------------------------------------------
# 로컬 개발용: 이 파일을 복사해 .env.local 을 만드세요 (Git에 커밋하지 않음)
#
#   cp .env.example .env.local
#
# Firebase Console → 프로젝트 cole-c3f96 → 프로젝트 설정 → 내 앱 → 웹 앱
# 에서 아래 값을 채웁니다. 실제 키는 .env.local 에만 두세요.
# ---------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=cole-c3f96.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cole-c3f96
VITE_FIREBASE_STORAGE_BUCKET=cole-c3f96.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=200339538980
VITE_FIREBASE_APP_ID=

# Android FirestoreInstances.DIARY_DATABASE_ID 와 동일 (변경 금지)
VITE_FIREBASE_DATABASE_ID=diary
